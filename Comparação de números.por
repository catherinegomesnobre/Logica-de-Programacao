programa
{
	
	funcao inicio()
	{
       inteiro numA, numB 

       escreva("Digite o primeiro número: ")
       leia(numA)

       escreva("Digite o segundo número: ")
       leia(numB)

      
       se(numA>numB){
       	escreva(numA, " é maior que ", numB)
       }senao{
       	escreva(numB, " é maior que ", numA)
       }

     
      }
}