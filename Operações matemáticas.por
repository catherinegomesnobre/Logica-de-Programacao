programa {
  funcao inicio() {
  inteiro numA, numB, resultado

  escreva("Digite o primeiro número: ")
  leia (numA)

  escreva("Digite o segundo número: ")
  leia (numB)

  escreva("A soma dos números é: ", numA+numB, "\n")
  escreva("A subtração dos números é: ", numA-numB, "\n")
  escreva("A multiplicação dos números é: ", numA*numB, "\n")
  escreva("A divisão dos números é: ", numA/numB)
  }
}
